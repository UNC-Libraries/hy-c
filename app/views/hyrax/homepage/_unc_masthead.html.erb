<div id="unc-search" class="row">
  <div class="col-sm-offset-0 col-sm-6 col-xs-offset-1 col-xs-11">
    <h1 class="repo-name"><span>UNC Library</span><br/> Carolina Digital Repository</h1>
  </div>
  <div class="col-sm-offset-0 col-sm-6 col-xs-offset-1 col-xs-11">
    <%= render "catalog/search_form" if controller_name == 'homepage' %>
  </div>
  <div class="link-tabs col-xs-12 col-sm-12">
    <ul class="list-unstyled pull-right">
      <li><div><%= link_to t('hyrax.links.browse_all'), main_app.search_catalog_path %></div></li>
      <li><div><%= link_to t('hyrax.links.browse_collections'), main_app.search_catalog_path(f: { human_readable_type_sim: ["Collection"]}) %></div></li>
      <li><div><%= link_to t(:'hyrax.links.departments'), main_app.facet_catalog_path(id: 'affiliation_label_sim') %></div></li>
      <% unless Flipflop.read_only? %>
        <li><div data-turbolinks="false"><i class="fa fa-arrow-circle-up" aria-hidden="true"></i>
          <%= link_to t('hyrax.links.deposit'), '#', class: 'all-unc-work-types',
                      data: { behavior: 'select-work', target: '#worktypes-to-create', 'create-type' => 'single' } %>
        </div></li>
      <% end %>
    </ul>
  </div>
</div>
